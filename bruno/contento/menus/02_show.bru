meta {
  name: Show menus
  type: http
  seq: 32
}

get {
  url: {{baseUrl}}/menus/:id-or-slug
  body: none
  auth: inherit
}

params:path {
  id-or-slug:
}

params:query {
  ~include: items
}

headers {
  Accept: application/json
  Content-Type: application/json
  Locale: {{locale}}
}

docs {
  summary:
  - Show a single menu

  endpoint:
  - method: GET
  - path: /menus/:id-or-slug

  query params:
  - include (string|array): Optional includes: items.
}
