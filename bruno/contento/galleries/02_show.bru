meta {
  name: Show galleries
  type: http
  seq: 102
}

get {
  url: {{baseUrl}}/galleries/:id-slug-or-code
  body: none
  auth: inherit
}

params:path {
  id-slug-or-code:
}

params:query {
  ~include: items
}

headers {
  Accept: application/json
  Content-Type: application/json
  Locale: {{locale}}
}
