docs {
  summary:
  - List menu items

  endpoint:
  - method: GET
  - path: /menu-items

  query params:
  - page (integer): Page number.
  - per_page (integer): Items per page.
  - sort_by (string): Sort field.
  - sort_dir (string): Sort direction: asc or desc.
  - exclude_all_scopes (boolean): Skip all model global scopes for this request.
  - exclude_active_scope (boolean): Skip only the active global scope.
  - exclude_date_range_scope (boolean): Skip only the visibility date-range global scope.
  - exclude_published_scope (boolean): Accepted shared scope toggle; only endpoints/models with a published scope use it.
  - id[] (integer[]): Filter by one or more menu item IDs.
  - menu_id (integer): Exact-match filter for menu_id.
  - parent_id (integer|null): Exact-match filter for parent_id.
  - title (string): Case-insensitive partial-match filter for title.
  - slug (string): Case-insensitive partial-match filter for slug.
  - link (string): Case-insensitive partial-match filter for link.
  - active (boolean): Exact-match filter for active.
  - sort_order (integer): Exact-match filter for sort_order.
  - visible_date_from (date): Exact-match filter for visible_date_from.
  - visible_date_from_start (date): Filter visible_date_from greater than or equal to this date.
  - visible_date_from_end (date): Filter visible_date_from less than or equal to this date.
  - visible_date_to (date): Exact-match filter for visible_date_to.
  - visible_date_to_start (date): Filter visible_date_to greater than or equal to this date.
  - visible_date_to_end (date): Filter visible_date_to less than or equal to this date.
  - created_at_start (date): Filter created_at greater than or equal to this date.
  - created_at_end (date): Filter created_at less than or equal to this date.
  - updated_at_start (date): Filter updated_at greater than or equal to this date.
  - updated_at_end (date): Filter updated_at less than or equal to this date.
  - is_active (boolean): Alias filter for active.
  - as_tree (boolean): Return menu items as a hierarchical tree ordered by sort_order within each sibling branch.
  - include (string|array): Optional includes: menu, parent, children.
}
