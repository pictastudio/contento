meta {
  name: Update menu items
  type: http
  seq: 39
}

patch {
  url: {{baseUrl}}/menu-items/:id-or-slug
  body: json
  auth: inherit
}

params:path {
  id-or-slug:
}

headers {
  Accept: application/json
  Content-Type: application/json
  Locale: {{locale}}
}

body:json {
  {
    "menu_id": 1,
    "parent_id": null,
    "title": "Updated Support",
    "link": "/help/support",
    "active": true,
    "sort_order": 10,
    "visible_date_from": null,
    "visible_date_to": null
  }
}
